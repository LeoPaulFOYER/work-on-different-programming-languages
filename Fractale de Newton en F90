module MonModule
  implicit none
contains


  function zn1r(a,b)
    implicit none
    real, intent(in) :: a, b
    real::zn1r
    zn1r = a-a/3.+(1./3.)*(((a**2)-(b**2)))/(((a**2) + (b**2))**2)
  end function zn1r


  function zn1c(a,b)
    implicit none
    real, intent(in) :: a, b
    real :: zn1c
    zn1c = (2./3.)*b - (1./3.)*((2*a*b)/(((a**2)+(b**2))**2))
  end function zn1c

  function trouver_convergence(znr,zni,N,convergence)
    implicit none
    integer, intent(in) :: N
    real, dimension(N), intent(in) :: zni, znr
    integer  :: convergence, trouver_convergence



    if (abs(1-znr(N)) <= (10**(-4))) then
       convergence = 1
    else if(abs((-1./2.)-znr(N)) <= (10**(-4)) .and. abs(((sqrt(3.))/2.) - zni(N)) <= 10**(-4)) then
       convergence = 2
    else if (abs((-1./2.)-znr(N)) <= (10**(-4)) .and. abs((((-sqrt(3.))/2.)) - zni(N)) <= 10**(-4)) then
       convergence = 3
    end if

    trouver_convergence=convergence

  end function trouver_convergence

  subroutine construction_suite(znr, zni,N)
    implicit none
    integer :: i
    integer, intent(in) :: N
    real, dimension(N), intent(out) :: zni, znr

    do i=2, N
       znr(i)=zn1r(znr(i-1), zni(i-1))
       zni(i)=zn1c(znr(i-1), zni(i-1))
    end do

  end subroutine construction_suite
end module MonModule

