program fractales
  use MonModule
  implicit none
  real :: zeroReel,ZeroComplex, a, b, xmax, ymax
  integer :: i, N, M, convergence
  real, dimension(:), allocatable :: zni, znr


  print*, 'sur quel domaine veux tu faire le dessin. Commence par me donner les abscisses, et le xmin en premier. :'
  read*, zeroReel
  print*,'donne moi la valeur de xmax'
  read*, xmax
  print*, 'Passons maintenant aux ordonnées. donne moi la valeur de ymin:'
  read*, zeroComplex
  print*,'donne moi la valeur de ymax'
  read*, ymax

  print*, 'quel est le nombre maximal>20 pour la divergence?'
  read*, N



  allocate (znr(1:N), zni(1:N))


  znr(1) = zeroReel
  zni(1) = zeroComplex


 
  open(unit = 10, file='convergence_en1.txt')
  open(unit = 11, file='convergence_en_impos.txt')
  open(unit = 12, file='convergence_en_imneg.txt')
  open(unit = 13, file='divergence2.txt')

  do while (znr(1)<=xmax)
     zni(1)=zeroComplex
     do while (zni(1)<=ymax )
        convergence=4
        if(zni(1) == 0) then
           zni(1) = 0.01
        end if
        if (znr(1) == 0) then
           znr(1)=0.01
        end if


        call construction_suite(znr,zni,N)
        convergence = trouver_convergence(znr,zni,N,convergence)


        if (convergence == 1) then
           write(10,*) znr(1), zni(1)
        else if (convergence == 2) then
           write(11,*) znr(1), zni(1)
        else if( convergence == 3) then
           write(12,*) znr(1), zni(1)
        else if(convergence == 4) then
           write(13,*) znr(1), zni(1)
        end if

        zni(1) = zni(1) + 0.01

     end do

     znr(1) = znr(1) + 0.01
  end do
  close(10)
  close(11)
  close(12)
  close(13)



end program fractales



