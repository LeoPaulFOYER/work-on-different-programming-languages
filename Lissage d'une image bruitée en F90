module stockage_mat
  implicit none
contains


  !------------------------------------ STOCKAGE MATRICE ------------------------------------


  subroutine stockage_matrice_U(U,u_matrice,n)
    implicit none
    integer :: i,j
    integer, parameter :: pr = selected_real_kind(15,300)
    integer, intent(in) :: n
    real(pr), dimension(1 : n**2), intent(in) :: U
    real(pr), dimension(1 : n , 1 : n):: u_matrice


    do i = 1 , n
       do j = 1 , n
          u_matrice(i,j) = U(i*n - n + j)
       end do
    end do

    open(unit=11, file='image_lissee.dat', status='replace', action='write')
    do i = 1,n
       write(11, *) (u_matrice(i, j), j = 1, n)

    end do
    close(11)

  end subroutine stockage_matrice_U

  
end module stockage_mat

