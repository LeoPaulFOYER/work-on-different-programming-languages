module gradient_conjugue
  use produit_sca_ou_mat_vect
  implicit none
contains


  !-------------RESOLUTION DU SYSTEME LINEAIRE PAR LE GRADIENT CONJUGUÉ ----------------------



  subroutine res_grad_conj(A,F,n,tol,U)

    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    real(pr), intent(in) :: tol
    real(pr) :: r2, alpha, r2_new, beta
    integer, intent(in) :: n
    integer :: i
    real(pr), dimension(1:n**2), intent(in) :: F
    real(pr), dimension(1:n**2), intent(out) :: U
    real(pr), dimension(1:n**2) :: r,p, AP 
    real(pr), dimension(1:n**2,1:n**2), intent(in) :: A


    U=0.
    r=F
    p=r
    r2 = psv(r,r,n**2)
    do i = 1,n**2       
       AP = pvm(p,A,n**2)
       alpha = r2/psv(p,AP, n**2)
       U=U+alpha*p

       r=r-alpha*AP
       r2_new = psv(r,r,n**2)
       if (sqrt(r2_new)<tol) then
          print*,i
          exit
       end if
       beta = r2_new/r2
       p = r + beta*p
       r2 = r2_new

       
    end do

  end subroutine res_grad_conj

end module gradient_conjugue


