module produit_sca_ou_mat_vect
  implicit none
contains

   !---------------------- PRODUIT SCALAIRE DE DEUX VECTEURS DE TAILLE L--------------------------------


  function psv(v1,v2,l)
    implicit none
    integer, intent(in) :: l
    integer, parameter :: pr = selected_real_kind(15,300)
    integer :: i
    real(pr) :: ps
    real(pr) :: psv
    real(pr), dimension(l), intent(in) :: v1,v2

    ps = 0
    do i = 1,l
       ps= ps + v1(i)*v2(i)
    end do
    psv = ps
  end function psv




  !--------------------- PRODUIT ENTRE UNE MATRICE ET UN VECTEUR ----------------------------


  function pvm(v,m,l)
    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    integer, intent(in) :: l
    integer :: i,j
    real(pr), dimension(l), intent(in) :: v
    real(pr), dimension(l):: pvm
    real(pr), dimension(l) :: p
    real(pr),dimension(l,l), intent(in) :: m


    p=0.
    do i=1,l
       do j = 1,l
          p(i) = p(i) + m(i,j)*v(j)
       end do
    end do
    pvm=p
  end function pvm


  
end module produit_sca_ou_mat_vect
