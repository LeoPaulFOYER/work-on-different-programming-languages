module construction_matrices
  implicit none

    !--------------------------------- SUBROUTINES & FONCTIONS --------------------------------


contains



  !-------------------------------- CONSTRUCTION DE F ------------------------------------


  subroutine construction_F(n,f1,F)
    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    integer :: i,j,k,n
    real(pr), dimension(1:n,1:n) :: f1
    real(pr), dimension(1:n*n) :: F

    open(unit=10, file='image_matrix.dat', status='old', action= 'read')
    do i = n, 1 ,-1
       read(10,*) (f1(i,j) , j= 1,n)
       do k = 1,n
          F(n*i-n+k)= f1(i,k)
       end do
    end do
    close(10)
  end subroutine construction_F


  !----------------------- LES SUBROUTINES POUR LA CONSTRUCTION DE A ----------------------



  subroutine construction_A(TI,I3,A,n)
    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    integer :: n
    real(pr), dimension(1:n**2,1:n**2) ::TI,I3,A

    A = I3-TI
  end subroutine construction_A



  subroutine construction_T(n,T)
    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    integer :: i,n
    real(pr), dimension(1:n,1:n) :: T
    do i=1,n
       T(i,i)=20
       if (i/=1) then
          T(i,i-1)=-4
          if(i/=2) then
             T(i,i-2) = -1
          end if    
       end if
       if(i/=n) then
          T(i,i+1)=-4
          if(i/=n-1) then
             T(i,i+2) = -1
          end if

          
       end if
    end do
    print*, T
  end subroutine construction_T



  subroutine construction_I(n,I3)
    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    integer :: n, i
    real(pr), dimension(1:n**2, 1:n**2) :: I3
    do i =1, n**2
       I3(i,i) = 1
    end do
  end subroutine construction_I

  subroutine construction_I2(n,I2)

    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    integer :: n, i
    real(pr), dimension(1:n, 1:n) :: I2
    do i =1, n
       I2(i,i) = 1
    end do

  end subroutine construction_I2



  subroutine construction_TI(n,TI,T,I2, quotient)
    implicit none
    integer, parameter :: pr = selected_real_kind(15,300)
    integer :: n,i
    real(pr) :: quotient
    real(pr), dimension(1:n**2,1:n**2) :: TI
    real(pr), dimension(1:n,1:n) :: T,I2

    do i=1,n

       TI((i-1)*n+1:i*n,(i-1)*n+1:i*n)=T(1:n,1:n)
       if(i/=1) then
          TI((i-1)*n+1:i*n,(i-2)*n+1:(i-1)*n) = (-5.)*I2(1:n,1:n)
       end if
       if(i/=n) then
          TI((i-1)*n+1:i*n,i*n+1:(i+1)*n) = (-5.)*I2(1:n,1:n)
       end if

    end do
    TI = quotient*TI
  end subroutine construction_TI



 



end module construction_matrices


